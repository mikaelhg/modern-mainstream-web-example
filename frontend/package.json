  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "lint": "biome lint src",
    "lint:fix": "biome lint src --fix",
    "format": "biome format src --write",
